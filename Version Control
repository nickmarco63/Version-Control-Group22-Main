name = input("What is your name? ")
word = input("What is your favorite word? ")


letterCount = {}
mostCommon = ""
highest = 0

for letter in word:
    if letter in letterCount:
        letterCount[letter] += 1
    else:
        letterCount[letter] = 1

for letter in letterCount:
    if letterCount[letter] > highest:
        highest = letterCount[letter]
        mostCommon = letter

print(f"Good Afternoon, {name}!")
print(f"The word {word}, has {len(word)} letters.")
print(f"The letter '{mostCommon}' appeared the most times ({highest} times).")
